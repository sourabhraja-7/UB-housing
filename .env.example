# Google Maps — get your key at https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API, Geocoding API, Directions API
# Restrict the key to your domains in Cloud Console > Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza_your_key_here

# Google Maps Map ID — create at Google Maps Platform > Map Management
# Must be a JavaScript Map ID with "Vector" enabled.
# The light/dark toggle uses google.maps.ColorScheme on a SINGLE Map ID,
# so you only need one (Google's default styles ship with both variants).
# Required for AdvancedMarkerElement.
NEXT_PUBLIC_GOOGLE_MAP_ID=your_map_id_here

# Supabase — get these from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# App URL (used for server-side API calls in listing detail page)
# Locally: http://localhost:3000
# On Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
